{
	"name": "website",
	"private": true,
	"type": "module",
	"scripts": {
		"dev": "vite dev --port 3000",
		"build": "vite build",
		"preview": "vite preview",
		"test": "vitest run",
		"format": "oxfmt",
		"format:check": "oxfmt --check",
		"lint": "oxlint",
		"lint:fix": "oxlint --fix",
		"check": "oxfmt --check && oxlint",
		"start": "node .output/server/index.mjs",
		"check-types": "tsc --noEmit",
		"chakra:typegen": "chakra typegen src/utils/chakra-theme.ts --tsconfig tsconfig.json",
		"chakra:typegen:watch": "chakra typegen src/utils/chakra-theme.ts --tsconfig tsconfig.json --watch",
		"postinstall": "chakra typegen src/utils/chakra-theme.ts --tsconfig tsconfig.json"
	},
	"dependencies": {
		"@chakra-ui/react": "^3.31.0",
		"@emotion/react": "^11.14.0",
		"@fontsource-variable/jetbrains-mono": "^5.2.8",
		"@fontsource-variable/newsreader": "^5.2.10",
		"@fontsource/instrument-sans": "^5.2.8",
		"@nature-urbaine/database": "workspace:*",
		"@nature-urbaine/emails": "workspace:*",
		"@tanstack/react-form": "^1.0.0",
		"@tanstack/react-query": "^5.66.5",
		"@tanstack/react-router": "^1.168.24",
		"@tanstack/react-router-ssr-query": "^1.131.7",
		"@tanstack/react-start": "^1.167.48",
		"@tanstack/router-plugin": "^1.167.26",
		"@uidotdev/usehooks": "^2.4.1",
		"@unpic/react": "^1.0.2",
		"nitro": "3.0.260415-beta",
		"react": "^19.2.0",
		"react-dom": "^19.2.0",
		"react-icons": "^5.5.0",
		"sharp": "^0.34.5",
		"zod": "^4.1.11"
	},
	"devDependencies": {
		"@chakra-ui/cli": "^3.35.0",
		"@testing-library/dom": "^10.4.0",
		"@testing-library/react": "^16.2.0",
		"@types/node": "^22.10.2",
		"@types/react": "^19.2.0",
		"@types/react-dom": "^19.2.0",
		"@vitejs/plugin-react": "^6.0.1",
		"jsdom": "^27.0.0",
		"typescript": "^5.7.2",
		"vite": "^8.0.10",
		"vitest": "^3.0.5",
		"web-vitals": "^5.1.0"
	}
}
