{
	"include": ["src/**/*.ts", "src/**/*.tsx"],
	"compilerOptions": {
		"target": "ES2022",
		"jsx": "react-jsx",
		"module": "ESNext",
		"moduleResolution": "bundler",
		"verbatimModuleSyntax": false,
		"allowImportingTsExtensions": true,
		"noEmit": true,
		"strict": true,
		"skipLibCheck": true,
		"types": ["node"]
	}
}
