{
	"name": "@nature-urbaine/database",
	"version": "0.1.0",
	"private": true,
	"type": "module",
	"exports": {
		".": "./src/index.ts",
		"./config": "./src/config.ts",
		"./types": "./src/payload-types.ts",
		"./utils/lexical": "./src/utils/lexical.ts"
	},
	"scripts": {
		"format": "oxfmt",
		"format:check": "oxfmt --check",
		"lint": "oxlint",
		"lint:fix": "oxlint --fix",
		"check": "oxfmt --check && oxlint",
		"typecheck": "tsc --noEmit",
		"payload": "PAYLOAD_CONFIG_PATH=./src/config.ts payload",
		"migrate": "PAYLOAD_CONFIG_PATH=./src/config.ts payload migrate",
		"migrate:create": "PAYLOAD_CONFIG_PATH=./src/config.ts payload migrate:create",
		"migrate:status": "PAYLOAD_CONFIG_PATH=./src/config.ts payload migrate:status",
		"migrate:down": "PAYLOAD_CONFIG_PATH=./src/config.ts payload migrate:down",
		"migrate:refresh": "PAYLOAD_CONFIG_PATH=./src/config.ts payload migrate:refresh",
		"migrate:reset": "PAYLOAD_CONFIG_PATH=./src/config.ts payload migrate:reset",
		"migrate:fresh": "PAYLOAD_CONFIG_PATH=./src/config.ts payload migrate:fresh",
		"generate:types": "PAYLOAD_CONFIG_PATH=./src/config.ts payload generate:types",
		"seed:dev": "NODE_ENV=development PAYLOAD_DROP_DATABASE=true payload run ./src/seed/index.ts",
		"seed:prod": "NODE_ENV=production payload run ./src/seed/index.ts"
	},
	"dependencies": {
		"@payloadcms/db-postgres": "3.84.1",
		"@payloadcms/richtext-lexical": "3.84.1",
		"@payloadcms/storage-s3": "3.84.1",
		"@types/jsdom": "^28.0.0",
		"graphql": "^16.12.0",
		"jsdom": "^27.4.0",
		"payload": "3.84.1",
		"sharp": "^0.34.5",
		"xlsx": "^0.18.5"
	},
	"devDependencies": {
		"@types/node": "^20.14.10",
		"@types/react": "^19.0.0",
		"typescript": "^5.8.2"
	}
}
