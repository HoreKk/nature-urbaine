{
	"name": "nature-urbaine",
	"version": "1.0.0",
	"private": true,
	"license": "MIT",
	"scripts": {
		"migrate": "pnpm --filter @nature-urbaine/database migrate",
		"migrate:create": "pnpm --filter @nature-urbaine/database migrate:create",
		"migrate:status": "pnpm --filter @nature-urbaine/database migrate:status",
		"migrate:down": "pnpm --filter @nature-urbaine/database migrate:down",
		"migrate:refresh": "pnpm --filter @nature-urbaine/database migrate:refresh",
		"migrate:reset": "pnpm --filter @nature-urbaine/database migrate:reset",
		"migrate:fresh": "pnpm --filter @nature-urbaine/database migrate:fresh",
		"generate:types": "pnpm --filter @nature-urbaine/database generate:types",
		"generate:importmap": "cd apps/cms-payload && pnpm generate:importmap",
		"seed:dev": "pnpm --filter @nature-urbaine/database seed:dev",
		"seed:prod": "pnpm --filter @nature-urbaine/database seed:prod",
		"dev:cms-payload": "cd apps/cms-payload && pnpm dev -p 3001",
		"dev:website": "cd apps/website && pnpm dev",
		"chakra:typegen": "pnpm --filter website chakra:typegen",
		"chakra:typegen:watch": "pnpm --filter website chakra:typegen:watch",
		"build:loose": "turbo build --env-mode=loose",
		"serve:web": "cd apps/website && pnpm start",
		"serve:admin": "cd apps/cms-payload && pnpm start",
		"format": "oxfmt",
		"format:check": "oxfmt --check",
		"lint": "oxlint",
		"lint:fix": "oxlint --fix",
		"check": "oxfmt --check && oxlint"
	},
	"devDependencies": {
		"lefthook": "^2.1.6",
		"oxfmt": "^0.46.0",
		"oxlint": "^1.61.0",
		"turbo": "^2.9.6"
	},
	"packageManager": "pnpm@10.28.2"
}
